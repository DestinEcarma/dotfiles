// Zed keymap
//
// For information off binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "context": "VimControl",
        "bindings": {
            // Indentations
            "ctrl-[": "editor::Outdent",
            "ctrl-]": "editor::Indent",
            "tab": "editor::Tab",
            "shift-tab": "editor::Backtab",

            // Move Lines
            "alt-j": "editor::MoveLineDown",
            "alt-k": "editor::MoveLineUp",
        },
    },
    {
        "context": "vim_mode == normal || !(Editor || Terminal)",
        "bindings": {
            "space f p": "file_finder::Toggle",
            "space f o": "projects::OpenRecent",
        },
    },
    {
        "context": "VimControl && vim_mode == normal",
        "bindings": {
            "ctrl-a": "editor::SelectAll",

            "space g d": "editor::GoToDefinition",
            "space g r": "editor::FindAllReferences",
            "space l i": "editor::ToggleInlayHints",
            "space c a": "editor::ToggleCodeActions",
            "space r a": "editor::Rename",

            // Diagnostics
            "space e": "editor::GoToDiagnostic",
            "space l e": "editor::ToggleInlineDiagnostics",
            "space f d": "diagnostics::Deploy",
        },
    },
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "a": "project_panel::NewFile",
            "r": "project_panel::Rename",
            "d": "project_panel::Trash",
            "y": "project_panel::Copy",
            "x": "project_panel::Cut",
            "p": "project_panel::Paste",
            "z": "project_panel::CollapseAllEntries",
            "f": "project_panel::RevealInFileManager",
            "t": "workspace::OpenInTerminal",
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "escape": "terminal::ToggleViMode",

            // Window Control
            "ctrl-w h": "workspace::ActivatePaneLeft",
            "ctrl-w j": "workspace::ActivatePaneDown",
            "ctrl-w k": "workspace::ActivatePaneUp",
            "ctrl-w l": "workspace::ActivatePaneRight",

            // Terminal Command Navigation
            "ctrl-p": ["terminal::SendKeystroke", "up"],
            "ctrl-n": ["terminal::SendKeystroke", "down"],
        },
    },
    {
        "bindings": {
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-j": "workspace::ActivatePaneDown",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-l": "workspace::ActivatePaneRight",
        },
    },
    {
        "bindings": {
            "ctrl-b l": "workspace::ToggleRightDock",
            "ctrl-b h": "workspace::ToggleLeftDock",
            "ctrl-q": "pane::CloseActiveItem",
        },
    },
]
